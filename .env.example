# Copy to .env and fill in what you use.

# LLM provider for narratives/advice: "ollama" (local, free) or "anthropic" (paid)
LLM_PROVIDER=ollama
# Where Ollama is listening; change if it runs on another machine
OLLAMA_HOST=http://localhost:11434
# Any model you've pulled, e.g. qwen3, qwen3:14b, qwen2.5:7b (see `ollama list`)
OLLAMA_MODEL=qwen3

# Only needed if LLM_PROVIDER=anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Free key for the macro regime tilt — https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
